// Prisma schema — linor-cloning-liner
// 공통 컨벤션: architecture/domain-model.md v0.3
// - ID 형식: cuid (Prisma 네이티브 v1)
// - 삭제 정책: hard delete
// - 타임스탬프: createdAt / updatedAt (camelCase, DB 컬럼은 @map으로 snake_case)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  emailVerified  DateTime? @map("email_verified")
  hashedPassword String?   @map("hashed_password") // Credentials 프로바이더용. OAuth 사용자는 null.
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  projects Project[]

  @@map("users")
}

// NextAuth OAuth 프로바이더 연결 정보.
// 한 User가 여러 프로바이더(Google, GitHub 등)로 로그인할 수 있으므로 1:N.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// NextAuth DB 세션 (JWT 전략에서는 사용되지 않으나, adapter 호환을 위해 유지).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// NextAuth 이메일 인증 토큰 (이메일 프로바이더 미사용이나, adapter 호환을 위해 유지).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("projects")
}
