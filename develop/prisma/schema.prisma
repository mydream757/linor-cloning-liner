// Prisma schema — linor-cloning-liner
// 공통 컨벤션: architecture/domain-model.md v0.3
// - ID 형식: cuid (Prisma 네이티브 v1)
// - 삭제 정책: hard delete
// - 타임스탬프: createdAt / updatedAt (camelCase, DB 컬럼은 @map으로 snake_case)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  emailVerified  DateTime? @map("email_verified")
  hashedPassword String?   @map("hashed_password") // Credentials 프로바이더용. OAuth 사용자는 null.
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  projects Project[]
  chats    Chat[]
  assets   Asset[]

  @@map("users")
}

// NextAuth OAuth 프로바이더 연결 정보.
// 한 User가 여러 프로바이더(Google, GitHub 등)로 로그인할 수 있으므로 1:N.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// NextAuth DB 세션 (JWT 전략에서는 사용되지 않으나, adapter 호환을 위해 유지).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// NextAuth 이메일 인증 토큰 (이메일 프로바이더 미사용이나, adapter 호환을 위해 유지).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats  Chat[]
  assets Asset[]

  @@index([userId])
  @@map("projects")
}

// AI 대화 세션. User 직접 소유, Project는 선택적 그룹핑.
model Chat {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  projectId String? @map("project_id")
  title     String  @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages         Message[]
  originatedAssets Asset[]

  @@index([userId])
  @@index([projectId])
  @@map("chats")
}

// Chat 내 개별 메시지.
model Message {
  id     String      @id @default(cuid())
  chatId String      @map("chat_id")
  role   MessageRole
  content String     @db.Text

  // 출처(citation) 메타데이터. 어시스턴트 응답의 [n] 배지와 대응.
  // JSON 배열: [{ index: number, title: string, url?: string, snippet?: string }]
  citations Json?

  // Asset 참조 메타데이터 (기능 4에서 실 Asset 연결 시 활성화).
  // 현재는 빈 배열 또는 null.
  referencedAssetIds String[] @map("referenced_asset_ids")
  generatedAssetId   String?  @map("generated_asset_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chat           Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  generatedAsset Asset? @relation(fields: [generatedAssetId], references: [id], onDelete: SetNull)

  @@index([chatId])
  @@map("messages")
}

enum MessageRole {
  user
  assistant
  system

  @@map("message_role")
}

// Asset — Document 또는 Reference. polymorphic.
// ADR-0014: 단일 테이블 + type discriminator + 개별 nullable 컬럼 하이브리드.
// - 공통 필드: id, userId, projectId?, type, title, originChatId?, createdAt, updatedAt
// - type='reference'일 때만 referenceKind/referenceUrl/referenceText 채움
// - type='document'일 때만 documentContent 채움
// 타입별 제약은 애플리케이션 레이어(zod discriminatedUnion, 타입 가드)에서 강제한다.
model Asset {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  projectId    String?   @map("project_id")
  type         AssetType
  title        String    @db.VarChar(200)
  originChatId String?   @map("origin_chat_id")

  // Reference 전용 (type='reference'일 때만)
  referenceKind ReferenceKind? @map("reference_kind")
  referenceUrl  String?        @map("reference_url")  @db.VarChar(2048)
  referenceText String?        @map("reference_text") @db.Text

  // Document 전용 (type='document'일 때만). TipTap JSON.
  documentContent Json? @map("document_content")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  originChat Chat?    @relation(fields: [originChatId], references: [id], onDelete: SetNull)

  // Message.generatedAssetId 역참조.
  generatingMessages Message[]

  @@index([userId])
  @@index([projectId])
  @@index([originChatId])
  @@index([userId, type])
  @@map("assets")
}

enum AssetType {
  document
  reference

  @@map("asset_type")
}

enum ReferenceKind {
  url
  text

  @@map("reference_kind")
}
