# ---------------------------------------------------------------------------
# 이 파일은 개발 환경 변수의 템플릿이다. 실제 값은 .env.local 에 저장하며,
# .env.local 은 .gitignore 에 의해 커밋되지 않는다.
#
# 사용법:
#   cp .env.example .env.local
#   # .env.local 을 열어 값을 채운 뒤 `pnpm dev` 실행
# ---------------------------------------------------------------------------

# Database ------------------------------------------------------------------
# docker-compose.yml 의 PostgreSQL 서비스에 연결한다.
# 리포지토리 루트에서 `docker compose up -d` 로 DB 기동 후 아래 URL 로 접속.
DATABASE_URL="postgresql://linor:linor_dev@localhost:5432/linor_cloning_liner"

# NextAuth ------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# openssl rand -base64 32 로 생성한 값을 넣는다.
NEXTAUTH_SECRET=""

# Anthropic (LLM) -----------------------------------------------------------
# https://console.anthropic.com 에서 발급. sk-ant- 로 시작.
ANTHROPIC_API_KEY=""
