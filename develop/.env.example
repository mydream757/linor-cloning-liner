# ---------------------------------------------------------------------------
# 환경변수 템플릿. 실제 값은 개발자 로컬에서 .env 와 .env.local 로 나눠 담는다.
#
# .env         ← DATABASE_URL 등 비민감 공용 설정 (Prisma CLI가 자동 로드)
# .env.local   ← NEXTAUTH_SECRET, ANTHROPIC_API_KEY 등 민감 정보
#
# 이유: Prisma 7 CLI는 .env만 자동 로드하고 .env.local을 로드하지 않는다.
# DATABASE_URL을 .env.local에 두면 pnpm prisma migrate/generate 등이
# "Cannot resolve environment variable: DATABASE_URL" 로 실패한다.
#
# 사용법:
#   cp .env.example .env          # DATABASE_URL만 복사해서 사용
#   cp .env.example .env.local    # 그 다음 .env.local에서 DATABASE_URL 줄은
#                                 # 제거하고 민감 값만 채운다
#
# 두 파일 모두 .gitignore 된다 (.env.example만 커밋됨).
# ---------------------------------------------------------------------------

# Database (→ .env) ---------------------------------------------------------
# docker-compose.yml 의 PostgreSQL 서비스에 연결한다.
# `docker compose up -d` 로 DB 기동 후 아래 URL 로 접속.
DATABASE_URL="postgresql://linor:linor_dev@localhost:5432/linor_cloning_liner"

# NextAuth (→ .env.local) ---------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# openssl rand -base64 32 로 생성한 값을 넣는다.
NEXTAUTH_SECRET=""

# Anthropic / LLM (→ .env.local) --------------------------------------------
# https://console.anthropic.com 에서 발급. sk-ant- 로 시작.
ANTHROPIC_API_KEY=""
